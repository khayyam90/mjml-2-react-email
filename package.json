{
  "name": "mjml-2-react-email",
  "version": "1.0.0",
  "description": "Convert MJML templates to React Email components and render to HTML",
  "scripts": {
    "start": "tsx src/index.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "mjml": "mjml input.mjml -o input.html"
  },
  "dependencies": {
    "@react-email/components": "^0.0.35",
    "@react-email/render": "^1.0.5",
    "domhandler": "^5.0.3",
    "htmlparser2": "^9.1.0",
    "react": "^19.2.7"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "@types/react": "^19.0.0",
    "mjml": "^5.3.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
